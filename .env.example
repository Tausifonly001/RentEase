# RentEase Environment Configuration
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# APP
APP_URL=http://localhost/rentease/

# SUPABASE
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# DATABASE (Supabase PostgreSQL)
DB_HOST=db.your-project.supabase.co
DB_PORT=5432
DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=your-db-password

# STRIPE
STRIPE_PUBLIC_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ADMIN EMAIL (GMAIL SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-gmail@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM_EMAIL=your-gmail@gmail.com
SMTP_FROM_NAME="RentEase Admin"

# USER EMAIL (RESEND)
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=notifications@yourdomain.com

# PUSH NOTIFICATIONS (ONESIGNAL)
ONESIGNAL_APP_ID=your-app-id
ONESIGNAL_REST_API_KEY=your-rest-api-key
ONESIGNAL_SAFARI_WEB_ID=

# GOOGLE MAPS
GEOCODE_API_URL=https://maps.googleapis.com/maps/api/geocode/json
GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# SHIPROCKET
SHIPROCKET_EMAIL=your-email@domain.com
SHIPROCKET_PASSWORD=your-shiprocket-password
SHIPROCKET_PICKUP_LOCATION_ID=your-location-id
SHIPROCKET_WEBHOOK_TOKEN=your-webhook-token
